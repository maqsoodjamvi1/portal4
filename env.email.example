#--------------------------------------------------------------------
# EMAIL (trial signup OTP verification)
#--------------------------------------------------------------------
# trial.enableEmailVerification = false
#
# Set to true when SMTP is configured (see email.* below):
# trial.enableEmailVerification = true
#
# email.protocol = smtp
# email.SMTPHost = smtp.example.com
# email.SMTPUser = your-smtp-user
# email.SMTPPass = your-smtp-password
# email.SMTPPort = 587
# email.SMTPCrypto = tls
# email.fromEmail = noreply@yourdomain.com
# email.fromName = TLive Education
#
# Optional Trial config overrides (app/Config/Trial.php):
# trial.mailFromEmail = noreply@yourdomain.com
# trial.mailFromName = TLive Education
