# --------------------------------------------------------------------
# ENVIRONMENT
# --------------------------------------------------------------------
CI_ENVIRONMENT = production
CI_DEBUG = 0

# --------------------------------------------------------------------
# APP
# --------------------------------------------------------------------
app.baseURL = 'http://localhost/school-management-system/public/'
app.forceGlobalSecureRequests = false
app.CSPEnabled = false

# --------------------------------------------------------------------
# DATABASE (UPDATED — IMPORTANT)
# --------------------------------------------------------------------
database.default.hostname = localhost
database.default.port     = 3306
database.default.database = admin_timessportal_live
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_general_ci
database.default.DBDebug  = true

# --------------------------------------------------------------------
# SESSION
# --------------------------------------------------------------------
app.sessionDriver = CodeIgniter\Session\Handlers\FileHandler
app.sessionSavePath = WRITEPATH/session
app.sessionCookieName = ci_session
app.sessionMatchIP = false

# --------------------------------------------------------------------
# CACHE (TEMPORARY SIMPLE SETUP)
# --------------------------------------------------------------------
cache.handler = file
cache.backup  = file
cache.prefix  = local_

# --------------------------------------------------------------------
# SECURITY
# --------------------------------------------------------------------
app.CSRFProtection = false