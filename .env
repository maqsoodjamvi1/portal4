# === Core ===
CI_ENVIRONMENT = development
app.baseURL    = 'https://portal4.timesoftsol.com/'
#openai.api_key = "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"
google.api_key = "AIzaSyAjzof8_CxVB7xaTlkNi87X7mRP1MpOFzw"

# 2) DeepSeek
deepseek.api_key = "sk-deepseek-xxxx"
deepseek.base_url = "https://api.deepseek.com/v1"

# 3) OpenRouter
openrouter.api_key = "sk-or-xxxx"
openrouter.base_url = "https://openrouter.ai/api/v1"

# === Sessions (faster & lean) ===
# Keep file sessions if Redis isn't set up yet; switch to Redis later (see step 3).
app.sessionDriver = CodeIgniter\Session\Handlers\FileHandler
app.sessionSavePath = WRITEPATH/session
app.sessionCookieName = ci_session
app.sessionMatchIP = false
app.CSRFProtection = true

# === Database (use PRIVATE host + persistent connections) ===
# Get the PRIVATE hostname from DO “Database ? Connection details ? Private network”.
database.default.hostname = db-mysql-nyc3-81353-do-user-29191560-0.d.db.ondigitalocean.com
database.default.port     = 25060
database.default.database = admin_timessportal_live
database.default.username = doadmin
database.default.password = "AVNS_XjCSzXgMuzcgFBP7syL"
database.default.DBDriver = MySQLi

# Performance toggles
database.default.pConnect = false         # reuse connections (like CI3)
database.default.DBDebug  = false         # no debug overhead in prod
database.default.cacheOn  = true          # enable CI query caching
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_general_ci
database.default.encrypt  = false         # safe to keep off inside VPC; use true only if you require SSL

# ===== Redis Cache =====
cache.handler = redis
cache.backup  = file
cache.redis.host = 127.0.0.1
cache.redis.port = 6379

# Cache driver
cache.handler = memcached
cache.backupHandler = file

# Optional: set a prefix to isolate caches per domain/instance
cache.prefix = portal4_

# Memcached connection (single or multiple servers)
memcached.host = 127.0.0.1
memcached.port = 11211
memcached.weight = 1
memcached.raw = false



