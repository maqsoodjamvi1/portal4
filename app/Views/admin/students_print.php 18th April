// Generate SLC function
function generateSlc(studentId, event) {
    event.preventDefault();
    
    Swal.fire({
        title: 'Generate School Leaving Certificate',
        text: 'Are you sure you want to generate SLC for this student?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, Generate',
        cancelButtonText: 'Cancel',
        showDenyButton: true,
        denyButtonText: 'Generate & Drop Student'
    }).then((result) => {
        const action = result.isConfirmed ? 'generate_only' : (result.isDenied ? 'drop_with_slc' : null);
        if (action) {
            processSlcGeneration(studentId, action);
        }
    });
}

function processSlcGeneration(studentId, action) {
    Swal.fire({
        title: 'Processing...',
        text: 'Generating School Leaving Certificate',
        allowOutsideClick: false,
        didOpen: () => Swal.showLoading()
    });

    fetch('<?= base_url('admin/addbulkstudents/generate-slc-ajax') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: new URLSearchParams({
            student_id: studentId,
            action: action,
            '<?= csrf_token() ?>': '<?= csrf_hash() ?>'
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: 'SLC Generated Successfully',
                html: `<p><strong>SLC Number:</strong> ${data.slc_no}</p>`,
                confirmButtonText: 'View SLC'
            }).then(() => {
                window.open('<?= base_url('admin/slc/view/') ?>' + data.slc_id, '_blank');
                $('#studentsTable').DataTable().ajax.reload();
            });
        } else {
            Swal.fire({ icon: 'error', title: 'Generation Failed', text: data.msg });
        }
    })
    .catch(error => {
        Swal.fire({ icon: 'error', title: 'Error', text: 'An error occurred' });
    });
}

