<script>
$(document).ready(function() {
    // Initialize Select2
    $('.select2').select2({
        theme: 'bootstrap4',
        width: '100%'
    });

    // Get current status filter value
    let showAllStudents = false; // Default: show only current students

    // Handle status filter toggle
    $('#btnCurrentOnly').on('click', function() {
        showAllStudents = false;
        table.ajax.reload();
    });

    $('#btnAllStudents').on('click', function() {
        showAllStudents = true;
        table.ajax.reload();
    });

    // Column configuration
    const columnConfig = [
        { data: 'rownum', title: '#', visible: true, orderable: false, searchable: false },
        { data: 'profile_photo', title: 'Photo', visible: true, orderable: false, searchable: false },
        { data: 'student_id', title: 'Student ID', visible: false, orderable: true },
        { data: null, title: 'Actions', visible: true, orderable: false, searchable: false },
        { data: 'reg_no', title: 'Reg No', visible: true, orderable: true },
        { data: 'student_name', title: 'Name', visible: true, orderable: true },
        { data: 'status_text', title: 'Status', visible: true, orderable: true },
        { data: 'father_name', title: 'Father', visible: true, orderable: true },
        { data: 'father_cnic', title: 'Father CNIC', visible: false, orderable: true },
        { data: 'std_cnic', title: 'Student CNIC', visible: false, orderable: true },
        { data: 'gender', title: 'Gender', visible: true, orderable: true },
        { data: 'dob', title: 'DOB', visible: true, orderable: true },
        { data: 'age', title: 'Age', visible: true, orderable: true },
        { data: 'class_name', title: 'Class', visible: true, orderable: true },
        { data: 'section_name', title: 'Section', visible: true, orderable: true },
        { data: 'discounted_amount', title: 'Discounted', visible: false, orderable: true },
        { data: 'date_of_admission', title: 'Admission Date', visible: true, orderable: true },
        { data: 'father_contact', title: 'Father Contact', visible: true, orderable: true },
        { data: 'mother_contact', title: 'Mother Contact', visible: false, orderable: true },
        { data: 'emergency_contact', title: 'Emergency', visible: false, orderable: true },
        { data: 'whatsapp_contact', title: 'WhatsApp', visible: false, orderable: true },
        { data: 'address', title: 'Address', visible: false, orderable: true },
        { data: 'previous_school', title: 'Previous School', visible: false, orderable: true },
        { data: 'ps_city', title: 'PS City', visible: false, orderable: true },
        { data: 'health_condition', title: 'Health Condition', visible: false, orderable: false },
        { data: 'major_injuries', title: 'Major Injuries', visible: false, orderable: false },
        { data: 'admission_class', title: 'Admission Class', visible: false, orderable: true },
        { data: 'caste', title: 'Caste', visible: false, orderable: true },
        { data: 'gr_no', title: 'GR No', visible: false, orderable: true },
        { data: 'gr_date', title: 'GR Date', visible: false, orderable: true },
        { data: 'std_type', title: 'Student Type', visible: false, orderable: true },
        { data: 'religion', title: 'Religion', visible: false, orderable: true },
        { data: 'father_email', title: 'Father Email', visible: false, orderable: true },
        { data: 'father_occupation', title: 'Father Occupation', visible: false, orderable: true },
        { data: 'm_name', title: 'Mother Name', visible: false, orderable: true },
        { data: 'city', title: 'City', visible: false, orderable: true },
        { data: 'hear_source', title: 'Heard From', visible: false, orderable: true },
        { data: 'emergency_contact_person', title: 'Emergency Person', visible: false, orderable: true },
        { data: 'relationship', title: 'Relationship', visible: false, orderable: true }
    ];

    // Action column renderer
    function renderActions(data, type, row) {
        const baseUrl = '<?= base_url('admin') ?>';
        const hasSlc = parseInt(row.has_slc) > 0;
        
        return `
            <div class="btn-group dropright">
                <a href="${baseUrl}/students/edit?id=${row.student_id}" class="btn btn-sm btn-primary" title="Edit">
                    <i class="fas fa-edit"></i>
                </a>
                <button type="button" class="btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown">
                    <span class="sr-only">Toggle Dropdown</span>
                </button>
                <div class="dropdown-menu">
                    <a class="dropdown-item" href="${baseUrl}/students/view/${row.student_id}">
                        <i class="fas fa-eye mr-2"></i> View Profile
                    </a>
                    <a class="dropdown-item" href="${baseUrl}/fee-chalan-single/download?id=${row.student_id}">
                        <i class="fas fa-file-invoice mr-2"></i> Fee Challans
                    </a>
                    <a class="dropdown-item" href="${baseUrl}/fee-chalan/add?id=${row.student_id}">
                        <i class="fas fa-plus-circle mr-2"></i> Create Challan
                    </a>
                    <div class="dropdown-divider"></div>
                    ${hasSlc ? 
                        `<a class="dropdown-item" href="${baseUrl}/slc/view/${row.slc_id}" target="_blank">
                            <i class="fas fa-certificate mr-2"></i> View SLC
                        </a>` :
                        `<a class="dropdown-item" href="#" onclick="generateSlc(${row.student_id}, event)">
                            <i class="fas fa-file-pdf mr-2"></i> Generate SLC
                        </a>`
                    }
                    <a class="dropdown-item" href="#" onclick="deleteStudent(${row.student_id}, event)">
                        <i class="fas fa-trash-alt mr-2 text-danger"></i> Delete
                    </a>
                </div>
            </div>
        `;
    }

    // Status badge renderer
    function renderStatus(data, type, row) {
        if (row.status == 1) {
            return '<span class="badge badge-success"><i class="fas fa-check-circle mr-1"></i> Current</span>';
        } else if (row.status == 4) {
            return '<span class="badge badge-danger"><i class="fas fa-exclamation-circle mr-1"></i> Dropped</span>';
        }
        return '<span class="badge badge-secondary">' + (data || 'Unknown') + '</span>';
    }

    // Initialize DataTable
    const table = $('#studentsTable').DataTable({
        processing: true,
        serverSide: true,
        scrollX: true,
        autoWidth: false,
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'All']],
        order: [[12, 'asc'], [13, 'asc'], [5, 'asc']],
        ajax: {
            url: "<?= site_url('admin/students_print/data') ?>",
            type: "POST",
            data: function(d) {
                d.search_name = $('#search_name').val();
                d.search_father = $('#search_father').val();
                d.class_id = $('#class_id').val();
                d.cls_sec_id = $('#cls_sec_id').val();
                d.show_all = showAllStudents;
                d.<?= csrf_token() ?> = '<?= csrf_hash() ?>';
            },
            dataSrc: function(json) {
                // Update stats
                if (json.recordsTotal) {
                    $('#totalStudentsCount').text(json.recordsTotal);
                }
                return json.data;
            }
        },
        columns: columnConfig.map((col, idx) => {
            if (idx === 3) {
                return { ...col, render: renderActions };
            }
            if (idx === 6) {
                return { ...col, render: renderStatus };
            }
            return col;
        }),
        buttons: [
            { extend: 'copy', text: '<i class="fas fa-copy"></i> Copy' },
            { extend: 'csv', text: '<i class="fas fa-file-csv"></i> CSV' },
            { extend: 'excel', text: '<i class="fas fa-file-excel"></i> Excel' },
            { extend: 'pdf', text: '<i class="fas fa-file-pdf"></i> PDF', orientation: 'landscape', pageSize: 'A3' },
            { extend: 'print', text: '<i class="fas fa-print"></i> Print' },
            { extend: 'colvis', text: '<i class="fas fa-columns"></i> Columns', columns: ':gt(3)' }
        ],
        dom: '<"row"<"col-sm-12 col-md-6"B><"col-sm-12 col-md-6"f>>' +
             '<"row"<"col-sm-12"tr>>' +
             '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>',
        language: {
            processing: '<i class="fas fa-spinner fa-spin fa-2x"></i> Loading...',
            search: '<i class="fas fa-search"></i> Search:',
            lengthMenu: '_MENU_ records per page',
            info: 'Showing _START_ to _END_ of _TOTAL_ students',
            infoEmpty: 'No students found',
            zeroRecords: 'No matching students found'
        }
    });

    // Apply filters
    $('#applyFilters').on('click', function() {
        table.ajax.reload();
    });

    // Reset filters
    $('#resetFilters').on('click', function() {
        $('#search_name').val('');
        $('#search_father').val('');
        $('#class_id').val('').trigger('change');
        $('#cls_sec_id').val('').trigger('change');
        // Reset status filter to "Current Only"
        $('#btnCurrentOnly').addClass('active');
        $('#btnAllStudents').removeClass('active');
        showAllStudents = false;
        table.ajax.reload();
    });

    // Enter key search
    $('#search_name, #search_father').on('keypress', function(e) {
        if (e.which === 13) {
            $('#applyFilters').click();
        }
    });

    // Export buttons
    $('#exportExcel').on('click', function() {
        table.button('.buttons-excel').trigger();
    });

    $('#exportPDF').on('click', function() {
        table.button('.buttons-pdf').trigger();
    });

    $('#toggleColumns').on('click', function() {
        table.button('.buttons-colvis').trigger();
    });

    // Adjust columns on window resize
    $(window).on('resize', function() {
        table.columns.adjust();
    });

    // ========== FLOATING ACTION BUTTONS (INSIDE DOCUMENT READY) ==========
    $('#scrollToTop').on('click', function() {
        $('.dataTables_scrollBody').animate({ scrollTop: 0 }, 300);
    });

